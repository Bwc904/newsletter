# Copy this file to .env and fill in real values.
# .env is gitignored and should never be committed.

# xAI Grok API key — get from https://console.x.ai
XAI_API_KEY=xai-your-key-here

# Email address to deliver the newsletter to
NEWSLETTER_TO=you@example.com

# Public base URL of the hosted edition (GitHub Pages)
NEWSLETTER_SITE_URL=https://bwc904.github.io/newsletter

# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here

# Sender — defaults to the Resend sandbox if unset; sandbox only delivers
# to the Resend account owner's email. Replace with a verified domain later.
# NEWSLETTER_FROM=Daily Brief <brief@yourdomain.com>
